---
import { name, roles } from '../data/profile';
---
<section id="heights" class="relative min-h-[108vh] flex items-center justify-center px-[7vw]">
  <div class="text-center">
    <h1 class="font-display text-ink-1 leading-[0.92] tracking-[-0.02em] text-[clamp(58px,11vw,128px)]"
        style="font-variation-settings:'opsz' 144,'SOFT' 60;">
      {name.first} <em class="italic text-ink-3 font-medium">{name.last}</em>
    </h1>
    <p class="font-display italic text-ink-3 mt-6 text-[clamp(15px,2.2vw,21px)]">{roles}</p>
  </div>
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 font-mono text-ink-4 text-[11px] tracking-[0.2em]">scroll</div>
</section>
