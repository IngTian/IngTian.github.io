---
import { name, roles, rolesSub, phd, bio } from '../data/profile';
import TerrainHero from '../components/TerrainHero.astro';

// Build the bio as HTML with the "strong" phrases wrapped in medium weight.
// Plain string replace is safe here: content is static and trusted (our own data).
let bioHtml = bio.text;
for (const phrase of bio.strong) {
  bioHtml = bioHtml.replace(phrase, `<strong class="font-medium text-ink-2">${phrase}</strong>`);
}
---
<section id="heights" class="relative min-h-[108vh] px-[7vw] pb-[12vh]">
  <TerrainHero />
  <!-- legibility: soft paper fades behind the name (bottom-left) and bio (top-right) -->
  <div class="hero-legibility" aria-hidden="true"></div>

  <!-- about-me, floated top-right; the empty diagonal to the name IS the composition -->
  <div class="hero-bio absolute top-[22vh] right-[7vw] max-w-[32ch] text-right">
    <p class="font-body text-ink-2/90 leading-[1.6] text-[clamp(13px,1.25vw,15.5px)]" set:html={bioHtml}></p>
  </div>

  <!-- name anchored bottom-left -->
  <div class="hero-rise absolute bottom-[16vh] left-[7vw] max-w-[88vw]">
    <h1 class="font-display text-ink-1 leading-[0.9] tracking-[-0.02em] text-[clamp(64px,12vw,132px)]"
        style="font-variation-settings:'opsz' 144,'SOFT' 60; text-shadow: 0 1px 18px rgba(22,20,15,0.06);">
      {name.first} <em class="italic text-ink-3 font-medium">{name.last}</em>
    </h1>
    <p class="hero-roles font-display italic text-ink-3 mt-5 text-[clamp(15px,2.2vw,21px)]">{roles}</p>
    <p class="hero-subline font-mono uppercase tracking-[0.22em] text-ink-3/90 mt-2.5 text-[11px]">{phd} &nbsp;·&nbsp; {rolesSub}</p>
  </div>

  <div class="scroll-cue absolute bottom-8 left-1/2 -translate-x-1/2 font-mono text-ink-4 text-[11px] tracking-[0.2em]">scroll</div>
</section>

<style>
  /* TerrainHero is position:absolute inset:0 z-0; keep text above it. */
  #heights .hero-rise, #heights .hero-bio { position: absolute; z-index: 2; }
  .hero-legibility {
    position: absolute; inset: 0; z-index: 1; pointer-events: none;
    background:
      /* name halo, bottom-left. Pulled up to 74% and tightened so the wash
         reaches fully transparent (~94% of the box) BEFORE the #heights bottom
         edge (108vh). Otherwise it was still ~0.12 opaque at the box boundary
         and got clipped in a straight horizontal line — that hard cut read as
         a faint divider at the hero/interlude seam.
         Uses --paper so it lifts the LIGHT text on the pale dawn; dark themes
         override below to a soft DARKEN behind the now-light text instead. */
      radial-gradient(40% 26% at 22% 74%, color-mix(in oklab, var(--paper) 85%, transparent), transparent 66%),
      radial-gradient(30% 22% at 82% 22%, color-mix(in oklab, var(--paper) 70%, transparent), transparent 72%);
  }
  /* Dark themes: the halo must DARKEN behind the light hero text, not brighten
     — a paper blob on a night sky would be a glaring smear. Swap to a soft
     near-black veil at the same anchor points. */
  :global(html[data-theme='dark']) .hero-legibility {
    background:
      radial-gradient(44% 30% at 22% 74%, color-mix(in oklab, var(--bg) 62%, transparent), transparent 68%),
      radial-gradient(34% 24% at 82% 22%, color-mix(in oklab, var(--bg) 46%, transparent), transparent 74%);
  }

  /* Mobile: a diagonal can't hold — collapse to a single LEFT-aligned stack
     (bio under the name), never re-centered. Static flow replaces the absolute
     positioning below the sm breakpoint. */
  @media (max-width: 640px) {
    #heights { display: flex; flex-direction: column; justify-content: flex-end; gap: 1.75rem; padding-bottom: 16vh; }
    #heights .hero-bio,
    #heights .hero-rise { position: static; inset: auto; max-width: 100%; text-align: left; right: auto; }
    #heights .hero-bio { order: 2; }
    #heights .hero-rise { order: 1; }
    #heights .hero-legibility { display: none; }
    #heights .terrain-canvas { opacity: 0.5; }
  }

  /* Large-screen type scale. Below 1536px (all mainstream laptops) NOTHING
     changes — the existing clamps already sit at their ceilings there. Above it,
     the hero type resumes growing so it holds presence against the full-bleed
     terrain on a 2K/QHD monitor instead of stranding tiny type in whitespace.
     Each formula is tuned continuous at 1536px (= the current cap, so no jump)
     and reaches its target at 2560px, then clamps (5K/4K logical widths ≤2560
     land on target; nothing runs away on ultrawide). The composition — name
     bottom-left, bio top-right, the empty diagonal — is unchanged; only sizes
     grow. Verified via CDP at 1536/1920/2560. */
  @media (min-width: 1536px) {
    #heights h1 { font-size: clamp(132px, calc(3.52vw + 78px), 168px); }
    #heights .hero-roles { font-size: clamp(21px, calc(0.684vw + 10.5px), 28px); }
    #heights .hero-subline { font-size: clamp(11px, calc(0.293vw + 6.5px), 14px); }
    #heights .hero-bio p { font-size: clamp(15.5px, calc(0.342vw + 10.25px), 19px); }
  }

  /* ULTRAWIDE / 4K / 5K (> 2560px). Two things happen together above 2560px:
     (1) the type resumes growing (it was frozen at the 2560 ceiling), and
     (2) the name/bio anchors detach from the viewport EDGE and re-anchor to a
     centered, bounded "composition stage" so the de-centered diagonal keeps its
     laptop-like proportions instead of sprawling into two stranded corners.

     The stage: a 2240px-wide centered band. The name pins to stage-left, the bio
     to stage-right, via `max(7vw, (100vw - 2240px)/2)`. The max() is the load-
     bearing seam: (100vw - 2240px)/2 only OVERTAKES 7vw at 2604px, so at 2560px
     both anchors still resolve to 7vw — byte-for-byte the shipped composition —
     and only above ~2604px does the stage take over. The terrain canvas stays
     full-bleed (it's the atmospheric field, edge-to-edge is correct); only the
     TEXT is bounded. Result: void 56%→35% (3440), 59%→32% (3840), 66%→24% (5120)
     — the diagonal reads as one composed stage at every width. Type formulas are
     continuous at 2560 (each = its current ceiling there, no jump) and re-cap at
     3840 so 5K doesn't run away. Verified via CDP at 2560/3440/3840/5120. */
  @media (min-width: 2560px) {
    #heights .hero-rise { left: max(7vw, calc((100vw - 2240px) / 2)); }
    #heights .hero-bio  { right: max(7vw, calc((100vw - 2240px) / 2)); }
    #heights h1 { font-size: clamp(168px, calc(2.5vw + 104px), 200px); }
    #heights .hero-roles { font-size: clamp(28px, calc(0.469vw + 16px), 34px); }
    #heights .hero-subline { font-size: clamp(14px, calc(0.156vw + 10px), 16px); }
    #heights .hero-bio p { font-size: clamp(19px, calc(0.234vw + 13px), 22px); }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-rise { animation: hero-rise 1.4s cubic-bezier(0.22, 1, 0.36, 1) both; }
    .hero-bio  { animation: hero-rise 1.4s cubic-bezier(0.22, 1, 0.36, 1) 0.25s both; }
    @keyframes hero-rise {
      from { opacity: 0; transform: translate3d(0, 16px, 0); }
      to   { opacity: 1; transform: translate3d(0, 0, 0); }
    }
    .scroll-cue { animation: cue-bob 2.6s ease-in-out 1.4s infinite; }
    @keyframes cue-bob {
      0%, 100% { opacity: 0.5; transform: translate(-50%, 0); }
      50%      { opacity: 1;   transform: translate(-50%, 6px); }
    }
  }
</style>
