---
import Cloud from '../components/Cloud.astro';
import Cow from '../components/Cow.astro';
---
<section id="clouds" class="relative min-h-[150vh] overflow-hidden">
  <!-- Parallax cloud layers. Each .drift moves at a different rate as the
       section passes the viewport (CSS scroll-driven, off the main thread).
       Reduced-motion users get the static resting positions. -->
  <div class="drift drift-a absolute left-[-6%] top-[8vh] w-[60%] h-[180px]">
    <Cloud tone="#f6f1e6" opacity={0.95} seed={3} scale={16} />
  </div>
  <div class="drift drift-b absolute right-[-8%] top-[20vh] w-[55%] h-[160px]">
    <Cloud tone="#efe7d8" opacity={0.85} seed={7} scale={13} />
  </div>
  <div class="drift drift-c absolute left-[8%] top-[44vh] w-[70%] h-[200px]">
    <Cloud tone="#e6ddcd" opacity={0.8} seed={11} scale={18} />
  </div>
  <div class="drift drift-a absolute right-[-4%] top-[68vh] w-[58%] h-[170px]">
    <Cloud tone="#d8d2c6" opacity={0.7} seed={5} scale={14} />
  </div>
  <div class="drift drift-b absolute left-[-10%] top-[92vh] w-[66%] h-[190px]">
    <Cloud tone="#cdc8be" opacity={0.62} seed={9} scale={15} />
  </div>

  <!-- Hidden cows tucked among the clouds; hover/focus to find them. -->
  <div class="drift drift-c absolute left-[22%] top-[30vh] w-[88px]">
    <Cow label="moo~" />
  </div>
  <div class="drift drift-a absolute right-[24%] top-[58vh] w-[68px]">
    <Cow flip label="moo moo~" />
  </div>
  <div class="drift drift-b absolute left-[40%] top-[104vh] w-[78px]">
    <Cow label="moo~ moo~" />
  </div>
</section>

<style>
  /* parallax: only when motion is welcome */
  @media (prefers-reduced-motion: no-preference) {
    .drift {
      animation: drift-up linear both;
      animation-timeline: view();
      animation-range: cover;
      will-change: transform;
    }
    /* three depths — far clouds move least, near clouds most */
    .drift-a { --shift: 40px; }
    .drift-b { --shift: 90px; }
    .drift-c { --shift: 150px; }
    @keyframes drift-up {
      from { transform: translate3d(0, calc(var(--shift) * 1), 0); }
      to   { transform: translate3d(0, calc(var(--shift) * -1), 0); }
    }
  }
</style>
