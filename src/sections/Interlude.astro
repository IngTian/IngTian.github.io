---
// A short, quiet transition between the hero and the experience — a single
// editorial statement set in the warming Monet sky. Swiss restraint: one line,
// generous space, no ornament. Replaces the old (weak) painted-cloud section.
---
<section id="interlude" class="relative min-h-[78vh] flex items-center justify-center px-[8vw]">
  <p class="statement max-w-[20ch] text-center font-display italic text-ink-2 leading-[1.35] text-[clamp(24px,3.6vw,40px)]">
    A researcher by day, <a class="art-link" href="/art">an artist by night</a>, and a mathematician at heart.
  </p>
</section>

<style>
  /* Quiet doorway: ink text with an underline that draws in from the left on
     hover/focus. No color shift (the seal stays reserved for the seal mark). */
  .art-link {
    color: inherit;
    text-decoration: none;
    position: relative;
    white-space: nowrap;
  }
  .art-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -0.06em;
    width: 100%;
    height: 1px;
    background: currentColor;
    opacity: 0.7;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.4s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .art-link:hover::after,
  .art-link:focus-visible::after { transform: scaleX(1); }
  /* keyboard focus stays visible even where transitions are reduced */
  .art-link:focus-visible { outline: 2px solid currentColor; outline-offset: 4px; border-radius: 2px; }
  /* reduced motion / no animation-timeline: show the underline statically so
     the affordance is never lost, just without the draw-in sweep */
  @media (prefers-reduced-motion: reduce) {
    .art-link::after { transition: none; }
    .art-link:hover::after, .art-link:focus-visible::after { transform: scaleX(1); }
  }

  @media (prefers-reduced-motion: no-preference) {
    .statement {
      animation: statement-in linear both;
      animation-timeline: view();
      animation-range: entry 5% cover 38%;
    }
    @keyframes statement-in {
      from { opacity: 0.15; transform: translate3d(0, 28px, 0); }
      to   { opacity: 1;    transform: translate3d(0, 0, 0); }
    }
  }
</style>
