---
// A short, quiet transition between the hero and the experience — a single
// editorial statement set in the warming Monet sky. Swiss restraint: one line,
// generous space, no ornament. Replaces the old (weak) painted-cloud section.
---
<section id="interlude" class="relative min-h-[78vh] flex items-center justify-center px-[8vw]">
  <p class="statement max-w-[20ch] text-center font-display italic text-ink-2 leading-[1.35] text-[clamp(24px,3.6vw,40px)]">
    <a class="research-link" href="/research">A researcher by day</a>, <a class="art-link" href="/art">an artist by night</a>, and a mathematician at heart.
  </p>
</section>

<style>
  /* Quiet doorway: ink text with an underline that draws in from the left on
     hover/focus. No color shift (the seal stays reserved for the seal mark). */
  .art-link {
    color: inherit;
    text-decoration: none;
    position: relative;
    white-space: nowrap;
  }
  .art-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: -0.06em;
    width: 100%;
    height: 1px;
    background: currentColor;
    opacity: 0.7;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.4s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .art-link:hover::after,
  .art-link:focus-visible::after { transform: scaleX(1); }
  /* keyboard focus stays visible even where transitions are reduced */
  .art-link:focus-visible { outline: 2px solid currentColor; outline-offset: 4px; border-radius: 2px; }
  /* reduced motion / no animation-timeline: show the underline statically so
     the affordance is never lost, just without the draw-in sweep */
  @media (prefers-reduced-motion: reduce) {
    .art-link::after { transition: none; }
    .art-link:hover::after, .art-link:focus-visible::after { transform: scaleX(1); }
  }

  /* The "day" doorway → /research. A DIFFERENT affordance from the artist
     underline: a soft ochre highlighter wash sweeps in BEHIND the words on
     hover/focus (like a marker stroke), then the text rides on top. Transform-
     only; the seal red stays reserved. */
  .research-link {
    color: inherit;
    text-decoration: none;
    position: relative;
    white-space: nowrap;
    isolation: isolate; /* keep the wash's z-index local to this link */
  }
  .research-link::before {
    content: "";
    position: absolute;
    left: -0.12em;
    right: -0.12em;
    bottom: 0.02em;
    height: 0.62em;        /* a marker stripe over the lower part of the text */
    background: var(--ochre);
    opacity: 0.34;
    border-radius: 1px;
    z-index: -1;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 0.42s cubic-bezier(0.2, 0.7, 0.2, 1);
  }
  .research-link:hover::before,
  .research-link:focus-visible::before { transform: scaleX(1); }
  .research-link:focus-visible { outline: 2px solid currentColor; outline-offset: 4px; border-radius: 2px; }
  @media (prefers-reduced-motion: reduce) {
    .research-link::before { transition: none; }
    .research-link:hover::before, .research-link:focus-visible::before { transform: scaleX(1); }
  }

  /* Large-screen type scale — matches the hero (Heights.astro): unchanged below
     1536px, then the tagline resumes growing (40→54px by 2560px) so it holds the
     warm-sky interlude on a 2K monitor. Continuous at 1536px (=current cap, no
     jump), capped at 54px so ultrawide doesn't run away. */
  @media (min-width: 1536px) {
    .statement { font-size: clamp(40px, calc(1.367vw + 19px), 54px); }
  }

  @media (prefers-reduced-motion: no-preference) {
    .statement {
      animation: statement-in linear both;
      animation-timeline: view();
      animation-range: entry 5% cover 38%;
    }
    @keyframes statement-in {
      from { opacity: 0.15; transform: translate3d(0, 28px, 0); }
      to   { opacity: 1;    transform: translate3d(0, 0, 0); }
    }
  }
</style>
