---
import Timeline from '../components/Timeline.astro';
import Publications from '../components/Publications.astro';
import Awards from '../components/Awards.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { researchInterests, projects } from '../data/profile';
---
<section id="mountains" class="relative px-[7vw] py-[14vh]">
  <div class="relative z-10 max-w-[920px] mx-auto">
    <p class="font-mono text-[11px] tracking-[0.24em] uppercase text-paper/55">The story so far</p>
    <h2 class="font-display italic text-[26px] sm:text-[30px] text-paper mt-3 leading-snug">
      A quant who reasons in structure,<br />an engineer who makes the math run.
    </h2>

    <!-- Research interests — teaser; full themed list lives on /research -->
    <h3 class="font-mono text-[11px] tracking-[0.24em] uppercase text-paper/45 mt-14 mb-3">
      Research interests
    </h3>
    <ul class="flex flex-wrap gap-x-3 gap-y-2.5 max-w-[760px]" data-ri>
      {researchInterests.map((it) => (
        <li>
          <button
            type="button"
            class="ri-pill font-mono text-[12px] border rounded-full px-3.5 py-1.5"
            aria-expanded="false"
            aria-controls="ri-gloss"
            data-gloss={it.gloss}
          >
            {it.label}
          </button>
        </li>
      ))}
    </ul>
    <!-- One shared reveal region — the clicked pill's one-line gloss. The grid
         wrapper animates its row 0fr→1fr so opening eases the height open and the
         link / writing / experience below glide down rather than jump. Announced
         to AT via aria-live. -->
    <div class="ri-gloss-wrap" data-ri-gloss-wrap>
      <p id="ri-gloss" class="ri-gloss" aria-live="polite"></p>
    </div>
    <a href="/research" class="research-more inline-block mt-5 font-mono text-[12px] text-ochre/90 no-underline">
      Read the research →
    </a>

    <!-- Publications — the distinctive research signal, given prominence -->
    <h3 class="font-mono text-[11px] tracking-[0.24em] uppercase text-paper/45 mt-14 mb-2">Selected writing</h3>
    <Publications />

    <!-- Experience -->
    <h3 class="font-mono text-[11px] tracking-[0.24em] uppercase text-paper/45 mt-14 mb-2">Experience</h3>
    <Timeline />

    <!-- Projects — shipped artifacts (a teaser; full list lives on /projects).
         Placed after Experience + writing so engineering stays a clear second
         to the research signal. -->
    {projects.length > 0 && (
      <>
        <h3 class="font-mono text-[11px] tracking-[0.24em] uppercase text-paper/45 mt-14 mb-3">Projects</h3>
        <div class="max-w-[760px]">
          <ProjectCard project={projects[0]} variant="teaser" />
        </div>
        <a href="/projects" class="projects-more inline-block mt-5 font-mono text-[12px] text-ochre/90 no-underline">
          {projects.length > 1 ? 'See all projects →' : 'More on the project →'}
        </a>
      </>
    )}

    <!-- Awards — compact strip -->
    <Awards />
  </div>
</section>

<style>
  .research-more, .projects-more { transition: color 0.3s, letter-spacing 0.3s; }
  @media (hover: hover) {
    .research-more:hover, .projects-more:hover { color: var(--ochre); letter-spacing: 0.02em; }
  }

  /* Research-interest pills — buttons that lift & brighten on hover, and open a
     one-line gloss on click. The OPEN pill carries the vermilion seal dot (the
     site's one saturated color), reserved here for the meaningful "this is open"
     state rather than spent on hover. */
  /* Frosted-GLASS pills — the same liquid-glass material as the ProjectCard /
     CornerNav, and it FOLLOWS the theme like they do: a LIGHT frosted-white chip
     with dark ink text in the light theme (mirrors ProjectCard --full light),
     and a dark-tinted frost with paper text in the dark theme. Static backdrop
     blur (baked, never animated — taste rule) + edge highlight so the chip reads
     as glass on the gradient rather than a flat patch. */
  .ri-pill {
    display: inline-flex;
    align-items: center;
    cursor: pointer;
    color: var(--paper);                          /* light text on a translucent dark frost (5.9:1) */
    border-color: rgba(255, 255, 255, 0.16);
    background-color: rgba(22, 20, 15, 0.4);      /* dark frost — the gradient still reads through */
    -webkit-backdrop-filter: blur(12px) saturate(1.3);
    backdrop-filter: blur(12px) saturate(1.3);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.14), 0 4px 14px -10px rgba(0, 0, 0, 0.4);
    transition: color 0.35s, border-color 0.35s, background-color 0.35s,
                box-shadow 0.35s, transform 0.35s cubic-bezier(0.2, 0.7, 0.3, 1);
  }
  /* Dark theme: a dark-tinted frost + paper text so the chip reads on the void. */
  :global(html[data-theme='dark']) .ri-pill {
    color: var(--paper);
    border-color: rgba(220, 225, 220, 0.14);
    background-color: rgba(220, 225, 220, 0.05);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.06), 0 4px 14px -8px rgba(0, 0, 0, 0.5);
  }

  @media (hover: hover) {
    .ri-pill:hover {
      border-color: rgba(200, 163, 106, 0.7);
      background-color: rgba(200, 163, 106, 0.16);
    }
  }

  /* Seal dot — always present (as ::before) but collapsed to zero width, so on
     open it GROWS in. Animating its width drives the pill's own width, which makes
     the flex row reflow each frame: the neighbour eases over instead of jumping. */
  .ri-pill::before {
    content: '';
    flex: 0 0 auto;
    width: 0;
    height: 6px;
    border-radius: 50%;
    background: var(--seal);
    opacity: 0;
    margin-right: 0;
    transition: width 0.42s cubic-bezier(0.2, 0.7, 0.3, 1),
                margin-right 0.42s cubic-bezier(0.2, 0.7, 0.3, 1),
                opacity 0.3s ease;
  }

  /* Open state — ochre wash + firmed rim + the grown seal dot. Text color is
     left to inherit the theme-correct value (ink in light, paper in dark) so an
     open pill doesn't turn invisible-white on the light band. */
  .ri-pill.open {
    border-color: rgba(200, 163, 106, 0.6);
    background-color: rgba(200, 163, 106, 0.12);
  }
  .ri-pill.open::before {
    width: 6px;
    margin-right: 7px;
    opacity: 1;
  }

  /* The shared gloss line — serif, left-ruled. A grid wrapper animates its single
     row 0fr→1fr, so opening eases the gloss height open and everything below it
     (the link, Selected writing, Experience) glides down instead of jumping. The
     text itself fades in over the same beat. */
  .ri-gloss-wrap {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.45s cubic-bezier(0.2, 0.7, 0.3, 1);
  }
  .ri-gloss-wrap.show { grid-template-rows: 1fr; }

  .ri-gloss {
    overflow: hidden;
    min-height: 0; /* let the grid item collapse below its content height */
    max-width: 520px;
    padding: 14px 0 0 14px;
    border-left: 1px solid rgba(200, 163, 106, 0.4);
    font-family: var(--font-display);
    font-size: 13.5px;
    line-height: 1.65;
    color: rgba(239, 233, 221, 0.74); /* paper, dimmed */
    opacity: 0;
    transition: opacity 0.35s ease;
  }
  .ri-gloss-wrap.show .ri-gloss { opacity: 1; }

  /* Motion gate — the lift, the dot's growth, and the reflow it drives are motion;
     the no-motion state (instant color/border change, dot simply present) still
     reads as finished. */
  @media (prefers-reduced-motion: reduce) {
    .ri-pill, .ri-pill::before, .ri-gloss-wrap, .ri-gloss { transition: none; }
  }
  @media (prefers-reduced-motion: no-preference) and (hover: hover) {
    .ri-pill:hover { transform: translateY(-2px); }
  }
</style>

<script>
  // Click-to-reveal for the research-interest pills. One shared gloss region:
  // opening a pill shows its gloss and marks it with the seal dot; clicking the
  // open pill (or another) toggles/switches. Vanilla, no island — re-inits after
  // every View Transition swap with a teardown so handlers don't leak.
  function initResearchPills() {
    const list = document.querySelector<HTMLElement>('[data-ri]');
    const wrap = document.querySelector<HTMLElement>('[data-ri-gloss-wrap]');
    const gloss = document.getElementById('ri-gloss');
    if (!list || !wrap || !gloss) return;

    const pills = Array.from(list.querySelectorAll<HTMLButtonElement>('.ri-pill'));

    function onClick(e: MouseEvent) {
      const btn = (e.target as HTMLElement).closest<HTMLButtonElement>('.ri-pill');
      if (!btn) return;
      const wasOpen = btn.classList.contains('open');

      pills.forEach((p) => {
        p.classList.remove('open');
        p.setAttribute('aria-expanded', 'false');
      });

      if (wasOpen) {
        wrap!.classList.remove('show');
        // keep the text through the collapse; clear once it finishes (or now, if
        // motion is reduced and there's no transition to wait on) so AT doesn't
        // read a hidden line.
        if (parseFloat(getComputedStyle(wrap!).transitionDuration) === 0) gloss!.textContent = '';
        return;
      }

      btn.classList.add('open');
      btn.setAttribute('aria-expanded', 'true');
      gloss!.textContent = btn.dataset.gloss ?? '';
      wrap!.classList.add('show');
    }

    // clear the gloss text only after the collapse animation lands
    function onEnd(e: TransitionEvent) {
      if (e.propertyName === 'grid-template-rows' && !wrap!.classList.contains('show')) {
        gloss!.textContent = '';
      }
    }

    list.addEventListener('click', onClick);
    wrap.addEventListener('transitionend', onEnd);
    riTeardown = () => {
      list.removeEventListener('click', onClick);
      wrap.removeEventListener('transitionend', onEnd);
    };
  }

  let riTeardown: (() => void) | null = null;
  document.addEventListener('astro:page-load', () => {
    riTeardown?.();
    riTeardown = null;
    initResearchPills();
  });
</script>
