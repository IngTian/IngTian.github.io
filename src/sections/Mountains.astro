---
import Timeline from '../components/Timeline.astro';
---
<section id="mountains" class="relative px-[7vw] py-[14vh]">
  <div class="relative z-10 max-w-[760px] mx-auto">
    <p class="font-mono text-[11px] tracking-[0.24em] uppercase text-paper/55">The story so far</p>
    <h2 class="font-display italic text-[30px] text-paper mt-3 leading-snug">
      A researcher who thinks in distributions,<br />a builder who ships the whole stack.
    </h2>
    <Timeline />
  </div>
  <!-- Phase 3: lone ink water buffalo anchors here -->
  <div id="buffalo-slot" class="pointer-events-none absolute right-[6vw] bottom-[12vh] w-[min(280px,38vw)]"></div>
</section>
