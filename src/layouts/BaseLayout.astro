---
import '../styles/global.css';
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import CornerNav from '../components/CornerNav.astro';
import { name, roles, links } from '../data/profile';

interface Props {
  title?: string;
  description?: string;
  /** Line shown on the descent veil for this page. */
  veilLine?: string;
  /** Play the veil on a FRESH load of this page? (Transitions always play it.) */
  veilOnLoad?: boolean;
  /**
   * How the corner nav picks its (light-theme) text color:
   *  - 'scroll' (default): flip dark→paper by the descent fraction behind it
   *    (home & /art ride the full dawn→night gradient).
   *  - 'light': pin to dark text — for pages that stay pale top-to-bottom in
   *    light theme (/research is a reading page and never sinks to dark).
   * In DARK theme the text is always light regardless, so this only matters
   * for the light theme.
   */
  navZone?: 'scroll' | 'light';
  /** Set on non-content routes (404): emit robots=noindex and skip canonical. */
  noindex?: boolean;
}

const {
  title = 'Ing Tian — Quant Researcher · Portfolio Optimization',
  description = 'Ing Tian (Zeying Tian) — quant researcher in portfolio optimization and incoming Operations Research PhD at the University of Toronto. Also a full-stack software and ML engineer. Toronto.',
  veilLine = 'a researcher by day',
  veilOnLoad = false,
  navZone = 'scroll',
  noindex = false,
} = Astro.props;

// Per-page canonical + og:url. Astro.site is 'https://ingtian.github.io';
// resolve the current path against it so each route advertises its OWN URL
// (previously every page hardcoded the homepage — wrong for /research, /art,
// /projects social shares + canonicalization). new URL(...).href normalizes
// the trailing slash for us. The 404 route skips canonical (it's noindex).
const canonical = new URL(Astro.url.pathname, Astro.site).href;

// JSON-LD Person — the one structured-data type a personal portfolio benefits
// from, built from the résumé data so it never drifts from the visible content.
// Emitted once per page (it describes the person, not the page). links[] carries
// the profile URLs used for sameAs.
const personLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: `${name.first} ${name.last}`,
  url: Astro.site?.href,
  jobTitle: roles,
  sameAs: [
    links.find((l) => l.label === 'GitHub')?.href,
    links.find((l) => l.label === 'LinkedIn')?.href,
  ].filter((h): h is string => Boolean(h)),
  alumniOf: 'McGill University',
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Theme init — runs synchronously BEFORE first paint so there's no flash of
        the wrong theme. Resolves: explicit saved choice (localStorage) first,
        else the visitor's OS preference (prefers-color-scheme). Only 'dark' sets
        the attribute; light is the default (no attribute).

        Also re-applies on astro:after-swap: View Transitions replace <html> with
        the incoming page's markup (which has NO data-theme — it's runtime-set),
        so without this the theme would reset to light on every navigation. The
        listener fires before the new page paints, so there's no flash. The
        toggle in the corner nav writes localStorage and flips the attribute
        live; this keeps it stuck across page changes. */}
    <script is:inline>
      (function () {
        function applyTheme() {
          try {
            var saved = localStorage.getItem('theme'); // 'dark' | 'light' | null
            var dark = saved ? saved === 'dark'
                             : matchMedia('(prefers-color-scheme: dark)').matches;
            if (dark) document.documentElement.dataset.theme = 'dark';
            else document.documentElement.removeAttribute('data-theme');
          } catch (e) {}
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>
    <meta name="generator" content={Astro.generator} />

    {/* Favicons. SVG for crisp browser tabs; PNG fallbacks because Google Search
        renders a RASTER favicon (it does not use the SVG) — the 48px is its
        baseline, the 192/512 cover higher-DPI surfaces and PWA installs. */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta name="description" content={description} />
    {noindex ? <meta name="robots" content="noindex" /> : <link rel="canonical" href={canonical} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="https://ingtian.github.io/og-card.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Ing Tian — Quant Researcher · Portfolio Optimization" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://ingtian.github.io/og-card.png" />
    <script type="application/ld+json" set:html={JSON.stringify(personLd)} />
    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-body" preload />
    <Font cssVariable="--font-mono" />
    <ClientRouter />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    {/* Persistent top-right nav + theme toggle — global (all pages), so contact
        actions and the light/dark switch are always reachable. Rendered here
        (not per-page) means it survives View Transitions as part of the shell.
        navZone tells it how to pick light-theme text color per page. */}
    <CornerNav navZone={navZone} />
    {/* "The Descent" loader: a night veil covering the page wipes DOWNWARD off
        the bottom to reveal it. It plays on every home<->/art navigation, and on
        a fresh load only when this page opts in (veilOnLoad) — so entering the
        home page directly shows no veil, but the gallery (and all transitions)
        do. Each page carries its own line. transform/opacity only; gated behind
        prefers-reduced-motion (finished state = uncovered page). */}
    <div
      class="descent-veil"
      aria-hidden="true"
      data-veil
      data-veil-on-load={veilOnLoad ? 'true' : 'false'}
    >
      <span class="descent-veil__line">{veilLine}</span>
    </div>
  </body>
</html>

<style is:global>
  .descent-veil {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, #1d1b16, #16140f);
    /* default: parked off the bottom — so with no JS / reduced-motion the page
       is simply shown, never covered. .is-playing covers then wipes down. */
    transform: translateY(100%);
  }
  .descent-veil__line {
    font-family: var(--font-display), Georgia, serif;
    font-style: italic;
    font-size: clamp(18px, 3vw, 26px);
    color: rgba(239, 233, 221, 0.5);
    white-space: nowrap;
  }

  @media (prefers-reduced-motion: no-preference) {
    /* is-playing forces the covering state statically (flash-free even before
       the first animation frame), then the wipe animation drives it DOWN off
       the bottom; fill-mode forwards holds it cleared. */
    .descent-veil.is-playing {
      transform: translateY(0);
      animation: descent-veil-wipe 1.1s cubic-bezier(0.7, 0, 0.2, 1) forwards;
    }
    .descent-veil.is-playing .descent-veil__line {
      animation: descent-veil-fade 0.55s ease forwards;
    }
    @keyframes descent-veil-wipe {
      from { transform: translateY(0); }
      to   { transform: translateY(100%); }
    }
    @keyframes descent-veil-fade {
      from { opacity: 0.5; }
      to   { opacity: 0; }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .descent-veil { display: none; }
  }
</style>

<script is:inline>
  // Synchronous (parses before first paint) so a fresh opted-in load covers
  // with NO flash. `__descentVeilInit` (on window, which survives view
  // transitions) tells a fresh load apart from a transition re-run, so this and
  // the after-swap listener below never double-fire.
  (function () {
    function play() {
      var v = document.querySelector('[data-veil]');
      if (!v) return;
      v.classList.remove('is-playing');
      void v.offsetWidth; // restart the animation
      v.classList.add('is-playing');
    }
    window.__descentVeilPlay = play;
    if (!window.__descentVeilInit) {
      window.__descentVeilInit = true; // first load only
      var v = document.querySelector('[data-veil]');
      if (v && v.dataset.veilOnLoad === 'true') play(); // only /art opts in
    }
    // else: a transition re-run — the after-swap listener handles it.
  })();
</script>

<script>
  // Persists across view transitions (module scripts run once). Plays the
  // destination page's veil on every client-side navigation (both directions).
  document.addEventListener('astro:after-swap', () => {
    (window as unknown as { __descentVeilPlay?: () => void }).__descentVeilPlay?.();
  });
</script>
