---
import '../styles/global.css';
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  /** Line shown on the descent veil for this page. */
  veilLine?: string;
  /** Play the veil on a FRESH load of this page? (Transitions always play it.) */
  veilOnLoad?: boolean;
}

const {
  title = 'Ing Tian — Quant Researcher · Portfolio Optimization',
  description = 'Ing Tian (Zeying Tian) — quant researcher in portfolio optimization and incoming Operations Research PhD at the University of Toronto. Also a full-stack software and ML engineer. Toronto.',
  veilLine = 'a researcher by day',
  veilOnLoad = false,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Theme init — runs synchronously BEFORE first paint so there's no flash of
        the wrong theme. Resolves: explicit saved choice (localStorage) first,
        else the visitor's OS preference (prefers-color-scheme). Only 'dark' sets
        the attribute; light is the default (no attribute). The toggle in the
        corner nav writes localStorage and flips this attribute live. */}
    <script is:inline>
      (function () {
        try {
          var saved = localStorage.getItem('theme'); // 'dark' | 'light' | null
          var dark = saved ? saved === 'dark'
                           : matchMedia('(prefers-color-scheme: dark)').matches;
          if (dark) document.documentElement.dataset.theme = 'dark';
        } catch (e) {}
      })();
    </script>
    <meta name="generator" content={Astro.generator} />

    {/* Favicons. SVG for crisp browser tabs; PNG fallbacks because Google Search
        renders a RASTER favicon (it does not use the SVG) — the 48px is its
        baseline, the 192/512 cover higher-DPI surfaces and PWA installs. */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://ingtian.github.io" />
    <meta property="og:image" content="https://ingtian.github.io/og-card.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Ing Tian — Quant Researcher · Portfolio Optimization" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content="https://ingtian.github.io/og-card.png" />
    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-body" preload />
    <Font cssVariable="--font-mono" />
    <ClientRouter />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    {/* "The Descent" loader: a night veil covering the page wipes DOWNWARD off
        the bottom to reveal it. It plays on every home<->/art navigation, and on
        a fresh load only when this page opts in (veilOnLoad) — so entering the
        home page directly shows no veil, but the gallery (and all transitions)
        do. Each page carries its own line. transform/opacity only; gated behind
        prefers-reduced-motion (finished state = uncovered page). */}
    <div
      class="descent-veil"
      aria-hidden="true"
      data-veil
      data-veil-on-load={veilOnLoad ? 'true' : 'false'}
    >
      <span class="descent-veil__line">{veilLine}</span>
    </div>
  </body>
</html>

<style is:global>
  .descent-veil {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(180deg, #1d1b16, #16140f);
    /* default: parked off the bottom — so with no JS / reduced-motion the page
       is simply shown, never covered. .is-playing covers then wipes down. */
    transform: translateY(100%);
  }
  .descent-veil__line {
    font-family: var(--font-display), Georgia, serif;
    font-style: italic;
    font-size: clamp(18px, 3vw, 26px);
    color: rgba(239, 233, 221, 0.5);
    white-space: nowrap;
  }

  @media (prefers-reduced-motion: no-preference) {
    /* is-playing forces the covering state statically (flash-free even before
       the first animation frame), then the wipe animation drives it DOWN off
       the bottom; fill-mode forwards holds it cleared. */
    .descent-veil.is-playing {
      transform: translateY(0);
      animation: descent-veil-wipe 1.1s cubic-bezier(0.7, 0, 0.2, 1) forwards;
    }
    .descent-veil.is-playing .descent-veil__line {
      animation: descent-veil-fade 0.55s ease forwards;
    }
    @keyframes descent-veil-wipe {
      from { transform: translateY(0); }
      to   { transform: translateY(100%); }
    }
    @keyframes descent-veil-fade {
      from { opacity: 0.5; }
      to   { opacity: 0; }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .descent-veil { display: none; }
  }
</style>

<script is:inline>
  // Synchronous (parses before first paint) so a fresh opted-in load covers
  // with NO flash. `__descentVeilInit` (on window, which survives view
  // transitions) tells a fresh load apart from a transition re-run, so this and
  // the after-swap listener below never double-fire.
  (function () {
    function play() {
      var v = document.querySelector('[data-veil]');
      if (!v) return;
      v.classList.remove('is-playing');
      void v.offsetWidth; // restart the animation
      v.classList.add('is-playing');
    }
    window.__descentVeilPlay = play;
    if (!window.__descentVeilInit) {
      window.__descentVeilInit = true; // first load only
      var v = document.querySelector('[data-veil]');
      if (v && v.dataset.veilOnLoad === 'true') play(); // only /art opts in
    }
    // else: a transition re-run — the after-swap listener handles it.
  })();
</script>

<script>
  // Persists across view transitions (module scripts run once). Plays the
  // destination page's veil on every client-side navigation (both directions).
  document.addEventListener('astro:after-swap', () => {
    (window as unknown as { __descentVeilPlay?: () => void }).__descentVeilPlay?.();
  });
</script>
