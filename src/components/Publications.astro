---
import { publications } from '../data/profile';
---
<div class="max-w-[860px]">
  {publications.map((p) => {
    // Featured papers deep-link to the /research page (internal); others link
    // straight to their external href (arXiv etc.); a paper with neither is a
    // plain card.
    const internal = p.featured ? '/research' : undefined;
    const dest = internal ?? p.href;
    const external = !internal && !!p.href;
    const Tag = dest ? 'a' : 'div';
    return (
      <Tag
        href={dest}
        target={external ? '_blank' : undefined}
        rel={external ? 'noopener noreferrer' : undefined}
        class:list={[
          'group block py-5 border-t border-paper/15 no-underline',
          dest && 'transition-colors',
        ]}
      >
        <div class="flex items-baseline justify-between gap-4">
          <span class="font-mono text-[11px] text-paper/60">{p.authors}</span>
          <span class="font-mono text-[11px] text-paper/60 shrink-0">{p.year}</span>
        </div>
        <h3 class="text-[15px] font-medium text-paper mt-2 leading-snug group-hover:text-ochre transition-colors">
          {p.title}
        </h3>
        <p class="text-[12.5px] italic text-paper/70 mt-1">
          {p.venue}
          {external && <span class="not-italic text-ochre"> ↗</span>}
          {internal && <span class="not-italic text-ochre"> · read more →</span>}
        </p>
      </Tag>
    );
  })}
</div>
