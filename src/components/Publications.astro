---
import { publications } from '../data/profile';
---
<!-- Author-date citation block — one flowing hanging-indent paragraph per
     entry (authors, year, roman title, italic venue), the register quant/
     finance preprints actually use. Not IEEE-numbered: that convention reads
     as CS-conference, not q-fin/econ. -->
<div class="max-w-[860px] border-t border-paper/15">
  {publications.map((p) => {
    // Featured papers deep-link to the /research page (internal); others link
    // straight to their external href (arXiv etc.); a paper with neither is a
    // plain card.
    const internal = p.featured ? '/research' : undefined;
    const dest = internal ?? p.href;
    const external = !internal && !!p.href;
    const Tag = dest ? 'a' : 'div';
    return (
      <Tag
        href={dest}
        target={external ? '_blank' : undefined}
        rel={external ? 'noopener noreferrer' : undefined}
        class:list={[
          'group block py-5 border-b border-paper/10 no-underline',
          dest && 'transition-colors',
        ]}
      >
        <p class="pub-entry text-[15px] leading-[1.7] text-paper/90">
          <span class="font-mono text-[13px] font-medium tracking-[0.01em] text-paper">{p.authors}</span>
          {' '}<span class="font-mono text-[13px] text-paper/70">({p.year}).</span>{' '}
          <span class="font-display group-hover:text-ochre transition-colors">{p.title}.</span>
          {' '}<span class="font-display italic text-paper/65">{p.venue}.</span>
          {external && <span class="font-mono not-italic text-ochre"> ↗</span>}
          {internal && <span class="font-mono not-italic text-ochre"> read more →</span>}
        </p>
      </Tag>
    );
  })}
</div>

<style>
  /* Hanging indent — the physical shape of a references page: the first
     line sits flush left, any wrapped line indents under it. */
  .pub-entry { text-indent: -1.4em; padding-left: 1.4em; }
</style>
