---
// Persistent top-right utility nav — surfaces the "reach me" actions
// (GitHub · Email · CV · LinkedIn) from the very first paint, so a visitor
// never has to scroll to the foot of the page to make contact (issue #21).
//
// Mirrors the Toc pattern: plain Astro + a bundled vanilla <script> (NOT a
// React island), re-inits on astro:page-load with a teardown, and adapts its
// color to the sky beneath it. Where the Toc sits at the viewport MIDDLE and
// flips per-section, this nav is pinned to the TOP edge — so it flips on the
// gradient fraction painted directly behind it, dark ink on the pale upper
// sky → paper once the descent sinks into dusk. Ochre on hover, the site's
// one interaction accent.
//
// Hrefs come from profile.ts (the single source of résumé facts); the icons
// live here (presentation, not content). Built so the deferred light/dark
// theme toggle drops in as one more item with no restructuring.
import { links } from '../data/profile';

interface Props {
  /** 'scroll' = flip text color by the descent fraction behind the nav (home,
   *  /art). 'light' = pin to dark text (pages that stay pale in light theme,
   *  e.g. /research). Only affects the LIGHT theme; dark is always light text. */
  navZone?: 'scroll' | 'light';
}
const { navZone = 'scroll' } = Astro.props;

// Resolve hrefs from the profile links by label — keeps URLs in one place.
const href = (label: string) => links.find((l) => l.label === label)?.href ?? '#';

type Item = { key: string; label: string; href: string; external: boolean; icon: string };
const items: Item[] = [
  {
    key: 'github', label: 'GitHub', href: href('GitHub'), external: true,
    // GitHub mark (fill, currentColor)
    icon: '<path fill="currentColor" fill-rule="evenodd" clip-rule="evenodd" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"/>',
  },
  {
    key: 'email', label: 'Email', href: href('Email'), external: false,
    // Envelope (stroke, currentColor)
    icon: '<path fill="none" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" d="M1.75 3.75h12.5v8.5H1.75z"/><path fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" d="m2.25 4.25 5.75 4.5 5.75-4.5"/>',
  },
  {
    key: 'cv', label: 'CV', href: href('Download CV'), external: true,
    // Document with a download arrow (stroke, currentColor)
    icon: '<path fill="none" stroke="currentColor" stroke-width="1.3" stroke-linejoin="round" d="M3.75 1.75h5l3.5 3.5v9h-8.5z"/><path fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round" d="M8 7v4m0 0L6.4 9.4M8 11l1.6-1.6"/>',
  },
  {
    key: 'linkedin', label: 'LinkedIn', href: href('LinkedIn'), external: true,
    // LinkedIn "in" mark (fill, currentColor)
    icon: '<path fill="currentColor" d="M3.4 5.6H.9V14h2.5V5.6ZM2.15 1A1.45 1.45 0 1 0 2.15 3.9 1.45 1.45 0 0 0 2.15 1ZM14 9.28c0-2.3-1.23-3.37-2.86-3.37-1.32 0-1.91.72-2.24 1.23V5.6H6.4c.03.71 0 8.4 0 8.4h2.5V9.31c0-.22.02-.45.08-.6.18-.45.59-.91 1.28-.91.9 0 1.26.69 1.26 1.69V14H14V9.28Z"/>',
  },
];
---
<nav class="cnav" aria-label="Contact and profiles" data-cnav data-nav-mode={navZone}>
  <ul>
    {items.map((it) => (
      <li>
        <a
          href={it.href}
          data-key={it.key}
          aria-label={it.label}
          {...(it.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
        >
          <span class="pill" aria-hidden="true"></span>
          <span class="content">
            <svg class="ic" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true" set:html={it.icon}></svg>
            <span class="label">{it.label}</span>
          </span>
        </a>
      </li>
    ))}
    <li class="sep" aria-hidden="true"></li>
    <li>
      {/* Theme toggle. A real <button> (not a link) so it's keyboard-operable
          and announced correctly. Shows the moon (→ go dark) in light theme and
          the sun (→ go light) in dark theme; CSS swaps which glyph is visible
          off the <html data-theme>. Label + pressed state kept in sync by the
          inline script below. */}
      <button type="button" class="toggle" data-theme-toggle aria-label="Switch to dark theme" aria-pressed="false">
        <span class="pill" aria-hidden="true"></span>
        <span class="content">
          <svg class="ic ic-moon" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
            <path fill="currentColor" d="M6.2 1.6a6.4 6.4 0 1 0 8.2 8.2A5 5 0 0 1 6.2 1.6Z"/>
          </svg>
          <svg class="ic ic-sun" viewBox="0 0 16 16" width="16" height="16" aria-hidden="true">
            <circle cx="8" cy="8" r="3.1" fill="currentColor"/>
            <g stroke="currentColor" stroke-width="1.3" stroke-linecap="round">
              <path d="M8 .9v2.0M8 13.1v2.0M.9 8h2.0M13.1 8h2.0M2.9 2.9l1.4 1.4M11.7 11.7l1.4 1.4M13.1 2.9l-1.4 1.4M4.3 11.7l-1.4 1.4"/>
            </g>
          </svg>
        </span>
      </button>
    </li>
  </ul>
</nav>

<style>
  .cnav {
    position: fixed;
    top: clamp(14px, 2vw, 22px);
    right: clamp(14px, 7vw, 64px);
    z-index: 40;                 /* above Toc (30) and content */
  }

  /* ── The frosted-glass capsule. A rounded, lucid panel the links sit inside
     — translucent so the Monet sky reads through it, with a static backdrop
     blur (blur is BAKED via backdrop-filter, never animated — taste rule) and
     a hairline rim. Zone-adaptive: paper-frost on the pale hero, ink-frost on
     the deep bottom (like the reference). The frosted panel also lifts the
     background locally, which fixes the mid-grey dusk contrast band the old
     text-halo was patching — so the halo is gone. ── */
  .cnav ul {
    list-style: none; margin: 0; padding: 4px;
    display: flex; align-items: center; gap: 2px;
    border-radius: 999px;
    /* light-zone frost (default at top): warm paper glass */
    background: rgba(244, 239, 228, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.5);
    box-shadow: 0 2px 10px rgba(22, 20, 15, 0.06), inset 0 1px 0 rgba(255, 255, 255, 0.45);
    -webkit-backdrop-filter: blur(14px) saturate(1.15);
    backdrop-filter: blur(14px) saturate(1.15);
    transition: background 0.5s ease, border-color 0.5s ease, box-shadow 0.5s ease;
  }
  /* dark-zone frost: the sky has sunk into dusk/ink — a cool dark glass */
  .cnav[data-zone="dark"] ul {
    background: rgba(22, 20, 15, 0.42);
    border: 1px solid rgba(184, 177, 161, 0.22);
    box-shadow: 0 2px 14px rgba(0, 0, 0, 0.28), inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  /* Dark THEME: the whole page is a dark void top-to-bottom, so the light-zone
     (top-of-page) paper frost would be a bright blob. Force dark glass for BOTH
     zones; text is already light via the flipped tokens. */
  :global(html[data-theme='dark']) .cnav ul {
    background: rgba(12, 12, 16, 0.5);
    border: 1px solid rgba(184, 177, 161, 0.18);
    box-shadow: 0 2px 14px rgba(0, 0, 0, 0.4), inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }
  /* the light text should stay light in the top zone under the dark theme */
  :global(html[data-theme='dark']) .cnav a,
  :global(html[data-theme='dark']) .cnav .toggle { color: var(--ink-1); }

  .cnav li { display: flex; }

  /* links AND the theme-toggle button share one capsule-item base */
  .cnav a, .cnav .toggle {
    position: relative;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    line-height: 1;
    padding: 9px 14px;
    border-radius: 999px;
    color: var(--ink-1);         /* light-zone ink */
    transition: color 0.35s ease;
    isolation: isolate;          /* keep the bloom pill under .content */
  }
  .cnav .toggle { background: none; border: 0; cursor: pointer; -webkit-appearance: none; appearance: none; padding: 9px 12px; }
  .cnav[data-zone="dark"] a, .cnav[data-zone="dark"] .toggle { color: var(--paper); }

  /* thin separator before the toggle — sets the utility control apart */
  .cnav .sep { width: 1px; align-self: stretch; margin: 4px 3px; background: currentColor; opacity: 0.18; }

  /* content sits above the bloom pill */
  .cnav .content { position: relative; z-index: 1; display: inline-flex; align-items: center; gap: 7px; }
  .cnav .ic { flex: none; display: block; }

  /* sun/moon swap: show the glyph for the ACTION (moon = go dark in light
     theme; sun = go light in dark theme). Default (light) shows moon. */
  .cnav .toggle .ic-sun { display: none; }
  :global(html[data-theme='dark']) .cnav .toggle .ic-moon { display: none; }
  :global(html[data-theme='dark']) .cnav .toggle .ic-sun { display: block; }

  /* ── The bloom pill — an accent capsule that grows in behind the item on
     hover/focus, inverting the text to dark ink. The accent (ochre light /
     phosphor-green dark) is the site's one interaction accent, so this reads
     as an evolution of the old "text turns accent" hover. transform/opacity. ── */
  .cnav .pill {
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: 999px;
    background: var(--ochre);
    opacity: 0;
    transform: scale(0.72);
    transition: opacity 0.32s ease, transform 0.32s cubic-bezier(0.34, 1.56, 0.64, 1);
    pointer-events: none;
  }

  @media (hover: hover) {
    .cnav a:hover .pill, .cnav .toggle:hover .pill { opacity: 1; transform: scale(1); }
    .cnav a:hover, .cnav .toggle:hover { color: var(--on-accent); }   /* dark ink reads on the accent */
    .cnav[data-zone="dark"] a:hover, .cnav[data-zone="dark"] .toggle:hover { color: var(--on-accent); }
    .cnav a:hover .content, .cnav .toggle:hover .content { animation: cnav-nudge 0.32s ease; }
  }
  .cnav a:focus-visible, .cnav .toggle:focus-visible { outline: none; color: var(--on-accent); }
  .cnav a:focus-visible .pill, .cnav .toggle:focus-visible .pill {
    opacity: 1; transform: scale(1);
    box-shadow: 0 0 0 2px color-mix(in oklab, var(--ochre) 55%, transparent);
  }

  @keyframes cnav-nudge {
    0% { transform: translateY(0); }
    45% { transform: translateY(-1.5px); }
    100% { transform: translateY(0); }
  }

  /* Mobile: icons only, tighter capsule — labels would crowd the top edge */
  @media (max-width: 640px) {
    .cnav { top: 12px; right: 14px; }
    .cnav ul { padding: 3px; }
    .cnav a, .cnav .toggle { padding: 9px 10px; }
    .cnav .label { position: absolute; width: 1px; height: 1px; overflow: hidden; clip: rect(0 0 0 0); white-space: nowrap; }
    .cnav .content { gap: 0; }
  }

  /* Reduced motion: no bloom scale / nudge — the pill still appears (instant)
     so the hover affordance survives, but nothing animates. */
  @media (prefers-reduced-motion: reduce) {
    .cnav ul, .cnav a, .cnav .toggle, .cnav .pill { transition: none; }
    .cnav a:hover .content, .cnav a:focus-visible .content,
    .cnav .toggle:hover .content, .cnav .toggle:focus-visible .content { animation: none; }
    .cnav .pill { transform: scale(1); }   /* no scale-in; just fade via opacity */
  }
</style>

<script>
  import { prefersReducedMotion } from '../lib/motion';

  // Zone the nav by the gradient fraction painted directly behind it. The
  // .descent gradient spans the full content height, so the sky color at the
  // nav's fixed top position maps to (scrollY + probe) / descentHeight — the
  // very thing that decides whether dark ink or paper stays legible. Above the
  // flip point the upper sky is pale (dark ink); below it the descent sinks
  // into dusk→ink (paper). Re-inits on every astro:page-load (View Transitions)
  // with a teardown so listeners don't leak across navigations.

  // Fraction of the descent at which paper text overtakes dark ink for
  // legibility behind the nav. Set to the measured contrast CROSSOVER: a probe
  // of the rendered sky shows ink-1 holds AA (≥4.5:1) down to ~0.55 and paper
  // takes over from ~0.57 upward, so flipping here keeps the higher-contrast
  // color on each side. (The lone mid-grey dusk point right at the crossover
  // sits just under 4.5 for both — the adaptive text-shadow halo covers it.)
  const DARK_FROM = 0.57;

  let teardown: (() => void) | null = null;

  function initCornerNav() {
    teardown?.();
    teardown = null;

    const nav = document.querySelector<HTMLElement>('[data-cnav]');
    if (!nav || !('requestAnimationFrame' in window)) return;
    const descent = document.querySelector<HTMLElement>('.descent');

    // Zone = which LIGHT-theme text color the nav uses. Two modes:
    //  - 'light': pinned dark text (pages that stay pale — /research). Set once.
    //  - 'scroll': flip dark→paper by the descent fraction behind the nav (home,
    //    /art, which ride the full dawn→night gradient). Needs a .descent el.
    // (Dark theme forces light text via CSS regardless of this attribute.)
    const mode = nav.dataset.navMode === 'light' ? 'light' : 'scroll';

    let onScroll: (() => void) | null = null;
    if (mode === 'light' || !descent) {
      nav.dataset.zone = 'light';
    } else {
      // document-y behind the nav's vertical center (fixed near the top edge)
      const probe = () => (nav.getBoundingClientRect().top + nav.getBoundingClientRect().bottom) / 2;
      const update = () => {
        const h = descent.offsetHeight;
        if (!h) return;
        const frac = (window.scrollY + probe()) / h;
        nav.dataset.zone = frac > DARK_FROM ? 'dark' : 'light';
      };
      let ticking = false;
      onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => { update(); ticking = false; });
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      update();
    }

    // ── Theme toggle ──────────────────────────────────────────────────────
    // Flip data-theme on <html>, persist the explicit choice, and keep the
    // button's a11y state in sync. The terrain canvas reads its palette from
    // data-theme once per init, so re-fire astro:page-load to make it (and any
    // other page-load-driven vanilla script) repaint for the new theme.
    const toggle = nav.querySelector<HTMLButtonElement>('[data-theme-toggle]');
    function syncToggle() {
      const dark = document.documentElement.dataset.theme === 'dark';
      if (!toggle) return;
      toggle.setAttribute('aria-pressed', String(dark));
      toggle.setAttribute('aria-label', dark ? 'Switch to light theme' : 'Switch to dark theme');
    }
    syncToggle();

    // The actual flip: swap the attribute, persist, sync a11y, and repaint the
    // canvas-based / page-load-driven pieces (terrain) for the new palette.
    function flipTheme() {
      const dark = document.documentElement.dataset.theme === 'dark';
      if (dark) { delete document.documentElement.dataset.theme; }
      else { document.documentElement.dataset.theme = 'dark'; }
      try { localStorage.setItem('theme', dark ? 'light' : 'dark'); } catch (e) {}
      syncToggle();
      document.dispatchEvent(new Event('astro:page-load'));
    }

    function onToggle() {
      // Animate the change as a full-page crossfade via the View Transitions
      // API — the whole site (gradient, text, canvas) dissolves from one theme
      // to the other. Falls back to an instant flip where the API is missing
      // (Firefox) or the user prefers reduced motion. The ::view-transition
      // fade timing is themed in global.css and gated on reduced-motion there.
      const startVT = (document as any).startViewTransition?.bind(document);
      if (startVT && !prefersReducedMotion()) {
        document.documentElement.classList.add('theme-vt');
        const t = startVT(flipTheme);
        t.finished.finally(() => document.documentElement.classList.remove('theme-vt'));
      } else {
        flipTheme();
      }
    }
    toggle?.addEventListener('click', onToggle);

    teardown = () => {
      if (onScroll) {
        window.removeEventListener('scroll', onScroll);
        window.removeEventListener('resize', onScroll);
      }
      toggle?.removeEventListener('click', onToggle);
    };
  }

  document.addEventListener('astro:page-load', () => {
    teardown?.();
    teardown = null;
    initCornerNav();
  });
</script>
