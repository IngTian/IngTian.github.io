---
import { timeline } from '../data/profile';
---
<div class="max-w-[680px]">
  {timeline.map((e) => (
    <div class="flex gap-6 py-5 border-t border-paper/15">
      <div class="font-mono text-[12px] text-paper/50 w-[104px] shrink-0 pt-1">{e.period}</div>
      <div>
        <h3 class="text-[16px] font-semibold text-paper">{e.title}</h3>
        <p class="text-[13px] text-paper/65 mt-1 leading-relaxed">{e.detail}</p>
      </div>
    </div>
  ))}
</div>
