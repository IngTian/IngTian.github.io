---
import { timeline } from '../data/profile';
---
<div class="mt-8 max-w-[680px]">
  {timeline.map((e) => (
    <div class="flex gap-6 py-5 border-t border-ink-3/25">
      <div class="font-mono text-[12px] text-ink-3 w-[104px] shrink-0 pt-1">{e.period}</div>
      <div>
        <h3 class="text-[16px] font-semibold text-ink-1">{e.title}</h3>
        <p class="text-[13px] text-ink-3 mt-1 leading-relaxed">{e.detail}</p>
      </div>
    </div>
  ))}
</div>
