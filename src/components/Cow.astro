---
// A small ink water-buffalo/cow brush mark hidden in the clouds. Low opacity
// until hovered/focused, then it darkens and a Latin "moo~" drifts up. Keyboard
// focusable (real <button>) so it's discoverable without a mouse. NO Chinese.
interface Props {
  flip?: boolean;
  label?: string;   // the moo text (Latin only)
}
const { flip = false, label = 'moo~' } = Astro.props;
---
<button class="cow" data-flip={flip ? '1' : '0'} aria-label="a hidden cow">
  <span class="moo" aria-hidden="true">{label}</span>
  <svg viewBox="0 0 100 64" aria-hidden="true">
    <g fill="var(--ink-2)">
      <!-- body: one confident gestural stroke -->
      <path d="M22,40 C20,28 34,22 52,23 C68,24 84,27 92,36 C90,44 78,44 72,40
               C58,50 34,50 26,44 C22,46 20,44 22,40 Z" />
      <!-- head + soft buffalo horn -->
      <path d="M88,32 C96,28 100,30 100,36 C96,40 90,40 86,37 Z" />
      <path d="M95,30 C100,22 99,16 94,16 C92,22 90,28 88,32 Z" opacity="0.85" />
      <!-- legs -->
      <rect x="34" y="46" width="4" height="14" rx="2" />
      <rect x="48" y="48" width="4" height="13" rx="2" />
      <rect x="62" y="48" width="4" height="13" rx="2" />
      <rect x="74" y="46" width="4" height="14" rx="2" />
      <!-- tail flick -->
      <path d="M22,40 C14,42 10,48 12,56" stroke="var(--ink-2)" stroke-width="2.5" fill="none" />
    </g>
  </svg>
</button>

<style>
  .cow {
    position: relative;
    display: block;
    width: 100%;
    background: none;
    border: 0;
    padding: 0;
    cursor: pointer;
    color: inherit;
  }
  .cow svg {
    display: block;
    width: 100%;
    height: auto;
    opacity: 0.24;
    transition: opacity 0.4s ease;
  }
  .cow[data-flip="1"] svg { transform: scaleX(-1); }
  .cow:hover svg,
  .cow:focus-visible svg { opacity: 0.66; }
  .moo {
    position: absolute;
    top: -22px;
    left: 60%;
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--ink-2);
    opacity: 0;
    white-space: nowrap;
    transform: translateY(4px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .cow:hover .moo,
  .cow:focus-visible .moo { opacity: 0.85; transform: translateY(-4px); }
  .cow:focus-visible { outline: none; }
</style>
