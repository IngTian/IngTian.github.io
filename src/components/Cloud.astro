---
// A single ink-wash cloud band: layered soft ellipses with a feTurbulence
// displacement filter for a wet, feathered edge. Static filter (CPU-baked),
// never animated. `tone` and `opacity` let callers place it in the descent.
interface Props {
  tone?: string;       // fill color
  opacity?: number;
  seed?: number;       // vary the turbulence so clouds don't repeat
  scale?: number;      // displacement strength (edge wobble)
}
const { tone = '#f3eee3', opacity = 0.9, seed = 2, scale = 14 } = Astro.props;
const fid = `cloud-edge-${seed}`;
---
<svg class="ink-cloud" viewBox="0 0 600 220" preserveAspectRatio="none" style={`opacity:${opacity}`} aria-hidden="true">
  <defs>
    <filter id={fid} x="-20%" y="-40%" width="140%" height="180%" color-interpolation-filters="sRGB">
      <feTurbulence type="fractalNoise" baseFrequency="0.012 0.02" numOctaves="2" seed={seed} result="n" />
      <feDisplacementMap in="SourceGraphic" in2="n" scale={scale} xChannelSelector="R" yChannelSelector="G" />
      <feGaussianBlur stdDeviation="6" />
    </filter>
  </defs>
  <g filter={`url(#${fid})`} fill={tone}>
    <ellipse cx="300" cy="120" rx="240" ry="52" />
    <ellipse cx="200" cy="100" rx="150" ry="44" />
    <ellipse cx="380" cy="104" rx="170" ry="46" />
    <ellipse cx="300" cy="92" rx="110" ry="38" />
  </g>
</svg>

<style>
  .ink-cloud { display: block; width: 100%; height: 100%; }
</style>
