---
// Paper grain — a baked SVG fractal-noise tile, static, full-viewport overlay.
// Adds the subtle "tooth" that separates real ink-wash from a flat gradient.
// Never animated (the spec's #1 perf rule); mix-blend multiply at very low opacity.
const noise = `<svg xmlns='http://www.w3.org/2000/svg' width='220' height='220'><filter id='n'><feTurbulence type='fractalNoise' baseFrequency='0.68' numOctaves='3' stitchTiles='stitch'/></filter><rect width='100%' height='100%' filter='url(%23n)'/></svg>`;
const dataUri = `url("data:image/svg+xml,${noise}")`;
---
<div class="paper-grain" aria-hidden="true" style={`background-image:${dataUri}`}></div>

<style>
  .paper-grain {
    position: fixed;
    inset: 0;
    z-index: 40;
    pointer-events: none;
    opacity: 0.09;
    mix-blend-mode: multiply;
    background-size: 200px 200px;
  }
</style>
