---
import { EQUATIONS } from '../lib/equations';
// Bubbles: mostly silent; rare Easter eggs. `word` = the cow; `mathml` = baked.
const bubbles = JSON.stringify([
  null, null, null, null,
  { word: '<span class="m">●</span> Moo!' },
  { mathml: EQUATIONS.gradZero },
  { mathml: EQUATIONS.gradZero },
  { mathml: EQUATIONS.kkt },
]);
---
<canvas id="terrain" class="terrain-canvas" aria-hidden="true" data-bubbles={bubbles}></canvas>
<div class="terrain-bubble" id="terrain-bubble" aria-hidden="true"></div>

<style>
  .terrain-canvas {
    position: absolute; inset: 0; width: 100%; height: 100%;
    z-index: 0; pointer-events: none; display: block;
  }
  .terrain-bubble {
    position: absolute; z-index: 1; color: var(--on-accent);
    background: var(--ochre); border: 1px solid color-mix(in oklab, var(--indigo) 55%, transparent);
    border-radius: 999px; padding: 4px 13px; white-space: nowrap;
    opacity: 0; transform: translateY(5px); pointer-events: none;
    box-shadow: 0 6px 18px rgba(0,0,0,.18);
  }
  @media (prefers-reduced-motion: no-preference) {
    .terrain-bubble { transition: opacity .45s, transform .45s; }
  }
  .terrain-bubble.show { opacity: 1; transform: none; }
  .terrain-bubble.word { font-family: var(--font-display); font-style: italic; font-size: 16px; }
  .terrain-bubble .m { color: color-mix(in oklab, var(--on-accent) 70%, var(--indigo)); font-style: normal; }
  .terrain-bubble math { color: var(--on-accent); font-size: 1.05em; }
</style>

<script>
  import { field, runDescent, project, SPAWNS,
           TERRAIN_LIGHT, TERRAIN_TERMINAL, type TerrainRamp } from '../lib/terrain';
  import { buildGrid, paintTerrain, TERRAIN_CONFIG_DEFAULTS, type GridPoint } from '../lib/terrainRender';
  import { prefersReducedMotion } from '../lib/motion';

  // The canvas is JS-painted, so it can't inherit CSS tokens — pick the ramp +
  // walker colors from the active theme (data-theme on <html>). Read fresh on
  // each init so a View-Transition swap or a live theme toggle repaints correctly.
  // Dark = the "terminal galaxy": cyan-blue "Glacier" ice dots read as a star
  // field on the charcoal void; light = the shipped warm "Classic" ochre→indigo.
  type WalkerPalette = { glow: [number,number,number]; settled: [number,number,number]; trail: [number,number,number] };
  // `darkness` (0 = light, 1 = dark) drives the directional-light value/gain
  // blend in the shared renderer so the relief reads on both the pale and the
  // dark sky. `dotScale` is a per-theme radius bump — dark gets a touch more (its
  // dots read as a fainter starfield on the void), light a little.
  function themePalette(): { ramp: TerrainRamp; walker: WalkerPalette; darkness: number; dotScale: number } {
    // Walker trios:
    //   dark  = Glacier — frost glow, ice settle, recessive teal trail (screensaver)
    //   light = Classic — the shipped paper glow, ochre settle, indigo trail
    if (document.documentElement.dataset.theme === 'dark')
      return { ramp: TERRAIN_TERMINAL, walker: { glow: [227,242,247], settled: [134,188,204], trail: [73,127,146] }, darkness: 1, dotScale: 1.18 };
    return { ramp: TERRAIN_LIGHT, walker: { glow: [244,239,228], settled: [200,163,106], trail: [92,108,140] }, darkness: 0, dotScale: 1.15 };
  }

  // Teardown handle for the previous init — re-init runs on every page load AND
  // after each View Transition swap (astro:page-load), so we must dispose the
  // prior instance's listeners / rAF loop / observer or they leak across
  // navigations and reference a stale (swapped-out) canvas. Without this, the
  // bowl field renders blank when you navigate back to home.
  let teardown: (() => void) | null = null;

  function initTerrain() {
    teardown?.();
    teardown = null;

    const cvs = document.getElementById('terrain') as HTMLCanvasElement | null;
    const bubbleEl = document.getElementById('terrain-bubble') as HTMLElement | null;
    if (!cvs || !bubbleEl) return;

    const ctx = cvs.getContext('2d')!;
    const reduce = prefersReducedMotion();
    const BUBBLES = JSON.parse(cvs.dataset.bubbles || '[]') as Array<null | { word?: string; mathml?: string }>;
    const { ramp, walker, darkness, dotScale } = themePalette();
    const [gr, gg, gb] = walker.glow;      // walker head-glow
    const [sr, sg, sb] = walker.settled;   // settled-at-minimum accent
    const [tr, tg, tb] = walker.trail;      // descending trail

    // The static-per-camera terrain: dot grid + precomputed normals + EDL shade,
    // built once (EDL is O(n²); the camera is fixed so it never needs recompute).
    // Config is the baked default (shape-reading on) plus this theme's ramp/darkness.
    // Same code path as /terrain-lab, so a value tuned there transfers verbatim.
    const cfg = { ...TERRAIN_CONFIG_DEFAULTS, ramp, darkness, dotScale };
    const ZOOM = cfg.zoom;                 // walkers must use the SAME zoom to stay on the surface
    let grid: GridPoint[] = buildGrid(cfg.edlParams);

    let W = 0, Hh = 0, DPR = 1;
    function resize() {
      DPR = Math.min(2, window.devicePixelRatio || 1);
      const r = cvs!.getBoundingClientRect();
      W = cvs!.width = Math.round(r.width * DPR);
      Hh = cvs!.height = Math.round(r.height * DPR);
    }
    resize();

    // descent walkers
    interface Walker { pts: Array<{x:number;y:number}>; born: number; done: boolean; retire: boolean; bubble: null | {word?:string;mathml?:string}; }
    const walkers: Walker[] = [];
    let spawnIx = 0, nextSpawnAt = 600;
    const STEP_MS = 680;
    function maybeSpawn(ts: number) {
      if (ts < nextSpawnAt) return;
      if (walkers.length && !walkers[walkers.length - 1].done) { nextSpawnAt = ts + 400; return; }
      const [sx, sy] = SPAWNS[spawnIx % SPAWNS.length];
      const bubble = BUBBLES[(spawnIx * 3 + 1) % BUBBLES.length];
      spawnIx++;
      walkers.push({ pts: runDescent(sx, sy), born: ts, done: false, retire: false, bubble });
      nextSpawnAt = ts + 4200 + (spawnIx % 3) * 900;
    }

    function frame(ts: number, animate: boolean) {
      ctx.clearRect(0, 0, W, Hh);
      const tsec = ts / 1000;
      const breathAmp = animate ? 0.04 : 0;
      const breathHz = 0.4;

      // Terrain dots (shared renderer): elevation color → directional relief +
      // warm/cool tint → Eye-Dome Lighting + elevation emphasis → bottom fade.
      // The bottom fade dissolves the bowl softly into the gradient instead of
      // ending in an abrupt dot-band at the hero's lower edge.
      paintTerrain(ctx, grid, cfg, W, Hh, DPR, tsec, breathAmp);

      // walkers (only when animating; static frame shows terrain only)
      let anyBubble: null | { x:number; y:number; b:{word?:string;mathml?:string} } = null;
      if (animate) {
        maybeSpawn(ts);
        const APPEAR = 160, TAIL = 4600, HOLD = 1600;
        for (const wk of walkers) {
          const elapsed = ts - wk.born;
          const shown = Math.min(wk.pts.length, Math.floor(elapsed / STEP_MS) + 1);
          if (shown >= wk.pts.length && !wk.done) { wk.done = true; }
          let maxAlpha = 0;
          for (let i = 0; i < shown; i++) {
            const pt = wk.pts[i];
            const z = field(pt.x, pt.y) + breathAmp * Math.sin(tsec * breathHz + pt.x * 0.7 + pt.y * 0.6);
            const [sx, sy] = project(pt.x, pt.y, z + 0.06, W, Hh, ZOOM);
            const isLast = i === wk.pts.length - 1;
            const age = ts - (wk.born + i * STEP_MS);
            const appear = Math.min(1, age / APPEAR);
            const life = (isLast && wk.done)
              ? Math.max(0, 1 - Math.max(0, age - HOLD) / 700)
              : Math.max(0, 1 - age / TAIL);
            const a = appear * life;
            if (a <= 0.01) continue;
            maxAlpha = Math.max(maxAlpha, a);
            const rr = (isLast ? 5.2 : 3.8) * DPR;
            ctx.beginPath(); ctx.arc(sx, sy, rr * 1.9, 0, 2 * Math.PI); ctx.fillStyle = `rgba(${gr},${gg},${gb},${0.5 * a})`; ctx.fill();
            ctx.beginPath(); ctx.arc(sx, sy, rr, 0, 2 * Math.PI);
            ctx.fillStyle = isLast && wk.done ? `rgba(${sr},${sg},${sb},${0.95 * a})` : `rgba(${tr},${tg},${tb},${a})`;
            ctx.fill();
            if (isLast && wk.done && a > 0.5 && wk.bubble) anyBubble = { x: sx, y: sy, b: wk.bubble };
          }
          if (wk.done && maxAlpha <= 0.01) wk.retire = true;
        }
        for (let i = walkers.length - 1; i >= 0; i--) if (walkers[i].retire) walkers.splice(i, 1);
      }

      // rare Easter-egg bubble
      if (anyBubble) {
        const b = anyBubble.b;
        const key = b.mathml || b.word || '';
        if (bubbleEl!.dataset.key !== key) {
          bubbleEl!.dataset.key = key;
          bubbleEl!.classList.toggle('word', !!b.word);
          bubbleEl!.innerHTML = b.word || b.mathml || '';
        }
        bubbleEl!.style.left = (anyBubble.x / DPR + 12) + 'px';
        bubbleEl!.style.top = (anyBubble.y / DPR - 44) + 'px';
        bubbleEl!.classList.add('show');
      } else { bubbleEl!.classList.remove('show'); bubbleEl!.dataset.key = ''; }
    }

    // Paint one finished frame immediately — instant LCP, and the guaranteed
    // baseline for reduced-motion / before the loop spins up.
    frame(0, false);

    // Resize handler: canvas resize clears the backing store, so repaint the
    // static frame under reduced-motion (otherwise the animation loop repaints).
    const onResize = () => { resize(); if (reduce) frame(0, false); };
    window.addEventListener('resize', onResize);

    // Under reduced-motion we stop here (static frame is the finished state).
    // Otherwise run the animation, paused while the hero is offscreen, and
    // throttled to ~30fps — imperceptible for this gentle motion, half the cost.
    let rafId = 0;
    let io: IntersectionObserver | null = null;
    if (!reduce) {
      let running = false, last = 0;
      const loop = (ts: number) => {
        if (ts - last > 33) { frame(ts, true); last = ts; }
        rafId = requestAnimationFrame(loop);
      };
      io = new IntersectionObserver((entries) => {
        const visible = entries[0].isIntersecting;
        if (visible && !running) { running = true; last = 0; rafId = requestAnimationFrame(loop); }
        else if (!visible && running) { running = false; cancelAnimationFrame(rafId); }
      }, { threshold: 0 });
      io.observe(cvs);
    }

    // Dispose everything this instance attached, so a later re-init (View
    // Transition swap) doesn't leave a stale rAF loop / observer / listener
    // pointing at the old canvas.
    teardown = () => {
      window.removeEventListener('resize', onResize);
      if (rafId) cancelAnimationFrame(rafId);
      io?.disconnect();
    };
  }

  // Run on first load and after every View Transition swap. astro:page-load
  // fires in both cases; if ClientRouter isn't present it still fires once.
  document.addEventListener('astro:page-load', initTerrain);
</script>
