---
// The lone ink water buffalo — the composition's anchor in the mountains.
// Gestural sumi-e strokes with a wet, feathered edge (static feTurbulence).
// A water buffalo (broad swept horns, heavy low body), never a charging bull.
// Sits at low opacity, part of the misty scene rather than a logo.
---
<svg class="buffalo" viewBox="0 0 320 200" aria-hidden="true">
  <defs>
    <filter id="buffalo-ink" x="-15%" y="-15%" width="130%" height="130%" color-interpolation-filters="sRGB">
      <feTurbulence type="fractalNoise" baseFrequency="0.018 0.026" numOctaves="2" seed="4" result="n" />
      <feDisplacementMap in="SourceGraphic" in2="n" scale="5" xChannelSelector="R" yChannelSelector="G" />
    </filter>
  </defs>
  <g filter="url(#buffalo-ink)" fill="var(--ink-1)">
    <!-- heavy low body, one loaded brush sweep -->
    <path d="M40,128 C36,98 78,82 132,84 C176,86 226,90 262,108
             C282,118 290,130 282,138 C268,150 240,144 228,136
             C200,156 120,158 86,146 C60,154 40,148 40,128 Z" />
    <!-- lowered head + broad swept buffalo horns (the humble bow) -->
    <path d="M262,108 C286,100 304,104 312,120 C302,130 284,128 274,120 Z" />
    <path d="M300,104 C322,86 326,64 308,58 C302,76 294,92 286,104 Z" opacity="0.92" />
    <path d="M288,110 C312,98 326,80 314,70 C306,84 296,100 282,108 Z" opacity="0.8" />
    <!-- four planted legs -->
    <rect x="76" y="148" width="8" height="40" rx="4" />
    <rect x="116" y="152" width="8" height="38" rx="4" />
    <rect x="206" y="152" width="8" height="38" rx="4" />
    <rect x="244" y="148" width="8" height="40" rx="4" />
    <!-- tail flick -->
    <path d="M40,128 C26,132 18,144 22,160" stroke="var(--ink-1)" stroke-width="4" fill="none" />
  </g>
</svg>

<style>
  .buffalo { display: block; width: 100%; height: auto; opacity: 0.5; }
</style>
